{
  "name": "lemma",
  "version": "0.1.0",
  "description": "基于 Claude Code 的学术写作桌面软件",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "cd frontend && vite",
    "build": "tsc -p frontend/tsconfig.json --noEmit && cd frontend && vite build && cd .. && tsc -p tsconfig.electron.json",
    "electron:dev": "concurrently \"cd frontend && vite\" \"tsc -p tsconfig.electron.json --watch\" \"wait-on http://localhost:5173 dist-electron/main.js && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "lint": "eslint frontend/src/ electron/ --ext .ts,.tsx --config frontend/.eslintrc.json --max-warnings=0",
    "typecheck": "tsc -p frontend/tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run",
    "test:frontend": "vitest run --project frontend",
    "test:electron": "vitest run --project electron",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.202",
    "chokidar": "^4.0.0",
    "idb-keyval": "^6.3.0",
    "lucide-react": "^1.21.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^6.1.2",
    "react-markdown": "^9.0.1",
    "react-virtuoso": "^4.18.10",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.0.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^10.0.3",
    "electron": "^39.8.10",
    "electron-builder": "^26.0.0",
    "electron-updater": "^6.3.0",
    "eslint": "^8.57.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "jsdom": "^24.1.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^7.0.2",
    "vite": "^5.4.21",
    "vitest": "^2.1.9",
    "wait-on": "^8.0.0"
  },
  "overrides": {
    "shell-quote": "^1.9.0"
  },
  "build": {
    "appId": "com.lemma.app",
    "productName": "Lemma",
    "directories": {
      "output": "dist"
    },
    "files": [
      "frontend/dist/**/*",
      "dist-electron/**/*",
      "domains/**/*"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Lemma",
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "language": "2052"
    }
  }
}
